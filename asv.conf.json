{
  "version": 1,
  "project": "pybroker",
  "project_url": "https://www.pybroker.com",
  "repo": ".",
  "branches": ["master"],
  "dvcs": "git",
  "environment_type": "virtualenv",
  "install_timeout": 600,
  "show_commit_url": "https://github.com/edtechre/pybroker/commit/",
  "pythons": ["3.12"],
  "install_command": [
    "in-dir={build_dir} python -mpip install ."
  ],
  "uninstall_command": [
    "return-code=any python -mpip uninstall -y {project}"
  ],
  "build_command": [],
  "benchmark_dir": "benchmarks",
  "env_dir": ".asv/env",
  "results_dir": ".asv/results",
  "html_dir": ".asv/html",
  "build_cache_size": 8
}
